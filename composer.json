{
    "name": "crazy-goat/scanmephp",
    "description": "Pure PHP QR code generator with zero dependencies",
    "type": "composer-plugin",
    "keywords": ["qr", "qrcode", "barcode", "generator", "php"],
    "homepage": "https://github.com/crazy-goat/ScanMePHP",
    "license": "MIT",
    "authors": [
        {
            "name": "Crazy Goat",
            "email": "crazy@goat.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brianium/paratest": "^7.0",
        "ext-gd": "*"
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\ScanMePHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CrazyGoat\\ScanMePHP\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "CrazyGoat\\ScanMePHP\\Composer\\Plugin"
    },
    "scripts": {
        "test": "phpunit",
        "test:fast": "php -d xdebug.mode=off vendor/bin/phpunit",
        "test:parallel": "paratest --processes=4 --colors --testdox"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
