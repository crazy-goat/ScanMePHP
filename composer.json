{
    "name": "crazy-goat/scanmephp",
    "description": "Pure PHP QR code generator with zero dependencies",
    "type": "library",
    "version": "0.2.0",
    "keywords": ["qr", "qrcode", "barcode", "generator", "php"],
    "homepage": "https://github.com/crazy-goat/ScanMePHP",
    "license": "MIT",
    "authors": [
        {
            "name": "Crazy Goat",
            "email": "crazy@goat.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "ext-gd": "*"
    },
    "autoload": {
        "psr-4": {
            "ScanMePHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScanMePHP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
